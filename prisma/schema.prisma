generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  password  String
  email     String   @unique
  role      Role     @default(USER)
  resumedata String  @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([email])
  @@index([role])
  @@map("users")
}

enum Role {
  ADMIN
  USER
}